{
  "name": "jewelry-maker-pro",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.jewelrymaker.pro",
    "productName": "Jewelry Maker Pro",
    "directories": {
